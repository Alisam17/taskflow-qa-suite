{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Task List",
  "type": "array",
  "minItems": 1,
  "items": {
    "type": "object",
    "required": ["id", "title", "status", "priority", "createdAt"],
    "properties": {
      "id": {
        "type": "integer",
        "minimum": 1
      },
      "title": {
        "type": "string",
        "minLength": 1,
        "maxLength": 200
      },
      "description": {},
      "status": {
        "type": "string",
        "enum": ["TODO", "IN_PROGRESS", "DONE", "CANCELLED"]
      },
      "priority": {
        "type": "string",
        "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"]
      },
      "createdAt": {
        "type": "string"
      },
      "updatedAt": {}
    }
  }
}
